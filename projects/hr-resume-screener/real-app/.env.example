# העתיקו ל-.env ומלאו. בלי הקובץ הזה האפליקציה רצה במצב דמו (נתונים מקומיים).

# 1) צרו integration ב-https://www.notion.so/my-integrations וקחו את הטוקן (secret_...)
NOTION_TOKEN=

# 2) שתפו את מסד המועמדים עם ה-integration, וקחו את ה-Database ID מה-URL
NOTION_DATABASE_ID=

# 3) (לא חובה) שמות המאפיינים (properties) במסד שלכם — אם שונים מברירת המחדל:
NOTION_PROP_NAME=Name
NOTION_PROP_CV=CV
NOTION_PROP_SCORE=Score
NOTION_PROP_REC=Recommendation
NOTION_PROP_REASON=Reasoning

# פורט (לא חובה)
PORT=4000
